COINCAP_API_KEY=your_api_key_here
SUPABASE_URL=https://your-supabase-url.supabase.co
SUPABASE_KEY=your_supabase_key_here
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url.supabase.co
NEXT_PUBLIC_SUPABASE_KEY=your_supabase_key_here

# AI Provider API Keys
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here
GROQ_API_KEY=your_groq_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
CLAUDE_API_KEY=your_claude_api_key_here

# AI Provider Models (optional - will use default if not set)
# Claude models: claude-opus-4-1, claude-sonnet-4-1, claude-haiku-4-5
# Default: claude-haiku-4-5
CLAUDE_MODEL=
# OpenAI models: gpt-4o, gpt-4-turbo, gpt-4o-mini
# Default: gpt-4o-mini
OPENAI_MODEL=
# Gemini models: gemini-2.0-flash-lite, gemini-2.0-flash, gemini-1.5-pro, gemini-1.5-flash, gemini-1.5-mini
# Default: gemini-2.0-flash-lite
GEMINI_MODEL=
# Groq models: llama-3.3-70b-versatile, mixtral-8x7b-32768, llama-3.1-70b-versatile
# Default: llama-3.3-70b-versatile
GROQ_MODEL=
# Deepseek models: deepseek-chat, deepseek-reasoner
# Default: deepseek-chat
DEEPSEEK_MODEL=
# OpenRouter - Leave empty to auto-select a free model, or specify a model ID
# Example: poolside/laguna-xs.2:free, meta-llama/llama-2-7b-chat:free
# Default: Auto-selects first available free model
OPENROUTER_MODEL=